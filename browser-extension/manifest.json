{
  "manifest_version": 3,
  "name": "FORTIMOVE Sourcing",
  "version": "1.0.0",
  "description": "상품 페이지에서 이미지/가격/브랜드를 1클릭으로 워크벤치에 전송합니다.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.iherb.com/*",
    "*://*.amazon.com/*",
    "*://*.amazon.co.jp/*",
    "*://*.amazon.co.uk/*",
    "*://*.taobao.com/*",
    "*://*.tmall.com/*",
    "*://*.1688.com/*",
    "*://*.rakuten.co.jp/*",
    "http://localhost:8051/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "FORTIMOVE에 보내기"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.iherb.com/pr/*",
        "*://*.amazon.com/*",
        "*://*.amazon.co.jp/*",
        "*://*.amazon.co.uk/*",
        "*://*.taobao.com/*",
        "*://*.tmall.com/*",
        "*://*.1688.com/*",
        "*://*.rakuten.co.jp/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
