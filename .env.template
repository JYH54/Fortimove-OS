# ============================================================
# Fortimove-OS Environment Variables Template
# 이 파일을 복사하여 각 서비스 디렉토리의 .env로 저장하세요
# cp .env.template image-localization-system/.env
# cp .env.template pm-agent/.env
# cp .env.template daily-scout/.env
# ============================================================

# ============================================================
# AI API (REQUIRED)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Gemini (이미지 생성/편집용)
# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# ============================================================
# Database (image-localization-system)
# ============================================================
DATABASE_URL=postgresql://fortimove:YOUR_DB_PASSWORD@db:5432/fortimove_images
DB_PASSWORD=YOUR_DB_PASSWORD

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================================
# Security
# ============================================================
SECRET_KEY=GENERATE_A_RANDOM_SECRET_KEY
ADMIN_TOKEN=GENERATE_A_RANDOM_ADMIN_TOKEN

# ============================================================
# Image Localization
# ============================================================
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=/tmp/fortimove-images
MAX_IMAGE_SIZE_MB=20
OUTPUT_IMAGE_WIDTH=1200
OUTPUT_IMAGE_QUALITY=85
OCR_ENGINE=easyocr
TRANSLATION_MODEL=claude-sonnet-4-5-20250929
INFANT_DETECTION_THRESHOLD=0.7

# ============================================================
# Daily Wellness Scout
# ============================================================
SCOUT_SCHEDULE_TIME=09:00
SCOUT_RUN_IMMEDIATELY=false
SCOUT_EMAIL_SENDER=your-email@gmail.com
SCOUT_EMAIL_PASSWORD=YOUR_APP_PASSWORD
SCOUT_EMAIL_RECIPIENTS=recipient@example.com
SCOUT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SCOUT_SLACK_URGENT_WEBHOOK_URL=

# ============================================================
# PM Agent
# ============================================================
HOST=127.0.0.1
PORT=8001
DB_PATH=data/approval_queue.db

# ============================================================
# Korean Law MCP (Optional)
# ============================================================
LAW_OC=YOUR_LAW_OC_KEY
