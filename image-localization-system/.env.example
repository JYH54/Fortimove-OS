# 데이터베이스
DATABASE_URL=postgresql://fortimove:your_db_password@localhost:5432/fortimove_images
DB_PASSWORD=your_db_password

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here  # 선택
STABILITY_API_KEY=your_stability_api_key_here  # 선택

# 보안
SECRET_KEY=your-super-secret-key-change-this-in-production

# AWS S3 (프로덕션)
STORAGE_PROVIDER=s3  # s3, gcs, local
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=fortimove-images
AWS_REGION=ap-northeast-2

# 앱 설정
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]

# 모니터링 (선택)
SENTRY_DSN=your_sentry_dsn_here
